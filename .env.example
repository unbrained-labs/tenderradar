# Neon Postgres — get from https://console.neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# simap.ch API — public endpoints work without a key,
# but registered accounts get higher rate limits.
# Register at https://www.simap.ch to get an account.
SIMAP_BASE_URL="https://www.simap.ch/api"
# SIMAP_API_KEY=""   # optional — add if you have one

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron secret — used to protect the /api/sync endpoint
CRON_SECRET="change-me-to-a-random-string"
