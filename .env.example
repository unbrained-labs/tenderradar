# Neon Postgres — get from https://console.neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron secret — used to protect /api/sync/* endpoints
CRON_SECRET="change-me-to-a-random-string"

# ─── Data Sources ─────────────────────────────────────────────────────────────

# simap.ch — Swiss public procurement (no key needed for public data)
# SIMAP_BASE_URL="https://www.simap.ch/api"  # override only for testing

# TED Europa — EU public procurement (no key needed)
# TED_BASE_URL="https://api.ted.europa.eu/v3"  # override only for testing

# SAM.gov — US federal procurement (REQUIRES API KEY — takes 1-4 days to activate)
# Register: https://sam.gov/content/entity-registration
# After registration, generate API key at: https://open.gsa.gov/api/get-opportunities-public-api/
# SAM_GOV_API_KEY="your_sam_gov_api_key_here"

# Find a Tender — UK public procurement (no key needed)
# FTS_BASE_URL="https://www.find-tender.service.gov.uk/api/1.0"  # override only for testing
